{
  "name": "@praxa/cli",
  "version": "0.2.0",
  "description": "CLI for governed AI agent missions, gateway diagnostics, and the Praxa agentic harness.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/praxa-labs/praxa#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praxa-labs/praxa.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/praxa-labs/praxa/issues"
  },
  "keywords": [
    "praxa",
    "agentic-harness",
    "ai-agent",
    "agent-cli",
    "agent-orchestration",
    "durable-agents",
    "automation",
    "human-in-the-loop",
    "oauth",
    "idempotency",
    "command-line"
  ],
  "files": ["bin", "dist", "README.md", "LICENSE", "NOTICE"],
  "bin": {
    "praxa": "./bin/praxa.mjs",
    "aura": "./bin/aura.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/arguments.d.ts",
      "import": "./dist/arguments.js"
    },
    "./init": {
      "types": "./dist/init.d.ts",
      "import": "./dist/init.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@praxa/sdk": "0.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
