{
  "name": "@praxa/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for governed AI agents, durable missions, agent memory, capabilities, SSE events, and the Praxa agentic harness.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/praxa-labs/praxa#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praxa-labs/praxa.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/praxa-labs/praxa/issues"
  },
  "keywords": [
    "praxa",
    "agentic-harness",
    "ai-agent",
    "agent-sdk",
    "agent-orchestration",
    "durable-agents",
    "agent-memory",
    "capability-discovery",
    "human-in-the-loop",
    "tool-execution",
    "oauth",
    "sse",
    "idempotency",
    "typescript"
  ],
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/generated-contracts.d.ts",
      "import": "./dist/generated-contracts.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  }
}
